# === AI Provider Configuration ===
# Provide API keys for the providers you want to use.
# At minimum, one key is required for the providers configured below.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# GEMINI_API_KEY=your-gemini-key-here
# OPENAI_API_KEY=sk-your-openai-key-here

# === Per-Task Model Configuration ===
# Provider: "anthropic", "gemini", or "openai"
# Model: any model name supported by that provider.
#
# Extraction (Call 1 — reads the label):
# EXTRACTION_PROVIDER=anthropic
# EXTRACTION_MODEL=claude-sonnet-4-6
#
# Secondary check (Call 2 — cross-check + linguistic):
# SECONDARY_PROVIDER=anthropic
# SECONDARY_MODEL=claude-sonnet-4-6

# === Recommended: Gemini extraction + Anthropic secondary (best quality/price) ===
# EXTRACTION_PROVIDER=gemini
# EXTRACTION_MODEL=gemini-3-flash-preview
# SECONDARY_PROVIDER=anthropic
# SECONDARY_MODEL=claude-sonnet-4-6

# === Example: OpenAI as secondary (triple cross-check possible) ===
# EXTRACTION_PROVIDER=gemini
# EXTRACTION_MODEL=gemini-3-flash-preview
# SECONDARY_PROVIDER=openai
# SECONDARY_MODEL=gpt-5.4-mini

# === Example: Full Gemini ===
# EXTRACTION_PROVIDER=gemini
# EXTRACTION_MODEL=gemini-3-flash-preview
# SECONDARY_PROVIDER=gemini
# SECONDARY_MODEL=gemini-3-flash-preview

# === Other settings ===
# FEDIAF_PDF_PATH=data/fediaf_guidelines_2021.pdf
# CROSS_CHECK_TOLERANCE=0.5
# MAX_TOKENS_MAIN=16384
# MAX_TOKENS_LINGUISTIC=8192
# LOG_LEVEL=WARNING
