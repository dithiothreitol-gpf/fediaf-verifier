# === AI Provider Configuration ===
# Provide API keys for the providers you want to use.
# At minimum, one key is required.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# GEMINI_API_KEY=your-gemini-key-here

# === Per-Task Model Configuration ===
# Provider: "anthropic" or "gemini"
# Model: any model name supported by that provider.
#
# Extraction (Call 1 — reads the label):
# EXTRACTION_PROVIDER=anthropic
# EXTRACTION_MODEL=claude-sonnet-4-6
#
# Secondary check (Call 2 — cross-check + linguistic):
# SECONDARY_PROVIDER=anthropic
# SECONDARY_MODEL=claude-sonnet-4-6

# === Example: Gemini for extraction, Anthropic for secondary ===
# EXTRACTION_PROVIDER=gemini
# EXTRACTION_MODEL=gemini-3-flash
# SECONDARY_PROVIDER=anthropic
# SECONDARY_MODEL=claude-sonnet-4-6

# === Example: Full Gemini ===
# GEMINI_API_KEY=AIza...
# EXTRACTION_PROVIDER=gemini
# EXTRACTION_MODEL=gemini-3-flash
# SECONDARY_PROVIDER=gemini
# SECONDARY_MODEL=gemini-3-flash

# === Other settings (unchanged) ===
# FEDIAF_PDF_PATH=data/fediaf_guidelines_2021.pdf
# CROSS_CHECK_TOLERANCE=0.5
# LOG_LEVEL=DEBUG
